# These packages are needed to build genefer: libgmp-dev ocl-icd-opencl-dev
# Compiler
COMP = clang
#COMP = gcc

ifeq ($(COMP), gcc)
CC = g++ -std=c++17
else
CC = clang++ -std=c++17
endif
RM = rm

ROOT_DIR = ..

BIN_DIR = $(ROOT_DIR)/bin
SRC_DIR = $(ROOT_DIR)/src

OCL_INC = -I$(ROOT_DIR)/Khronos
OCL_LIB = -lOpenCL

# BOINC source code: https://github.com/BOINC/boinc/archive/refs/tags/client_release/8.2/8.2.9.zip
# These packages are needed to build BOINC: m4 pkg-config autoconf libtool
# ./_autosetup
# ./configure --disable-server --disable-client --disable-manager
# api: make => libboinc_api.a libboinc_opencl.a
# lib: make => libboinc.a
BOINC_DIR = $(ROOT_DIR)/../boinc
BOINC_INC = -I$(BOINC_DIR) -I$(BOINC_DIR)/api -I$(BOINC_DIR)/lib
BOINC_LIB = $(BOINC_DIR)/api/libboinc_api.a $(BOINC_DIR)/lib/libboinc.a
BOINC_LIB_OCL = $(BOINC_DIR)/api/libboinc_opencl.a

CFLAGS = -DBOINC $(BOINC_INC) -Wall -Wextra -Wsign-conversion
ifeq ($(COMP), gcc)
OFLAGS = -ffinite-math-only -frename-registers -fprefetch-loop-arrays
else
OFLAGS = -ffinite-math-only -ffp-contract=fast -fno-trapping-math -fno-signed-zeros
endif
FLAGS_CPU = -O3
FLAGS_GPU = -O3 -DGPU

OBJS_CPU = main.o transform_neon.o sve_size.o transform_sve128.o transform_sve256.o transform_sve512.o
OBJS_GPU = maing.o transform_ocl.o
DEPS_COMMON = $(SRC_DIR)/transform.h $(SRC_DIR)/file.h $(SRC_DIR)/gint.h $(SRC_DIR)/pio.h $(SRC_DIR)/boinc.h
DEPS_MAIN = $(SRC_DIR)/genefer.h $(SRC_DIR)/timer.h $(DEPS_COMMON)
DEPS_TRANSFORM_CPUf64 = $(SRC_DIR)/transformCPUf64.h $(SRC_DIR)/transformCPUf64s.h $(SRC_DIR)/parallel.h $(SRC_DIR)/f64vector.h $(SRC_DIR)/f64vector_pair.h $(SRC_DIR)/simd128d.h $(SRC_DIR)/simd256d.h $(SRC_DIR)/simd512d.h $(DEPS_COMMON)
DEPS_TRANSFORM_GPU = $(SRC_DIR)/transformGPU.h $(SRC_DIR)/ocl.h $(DEPS_COMMON)

EXEC_CPU = $(BIN_DIR)/genefer_arm
EXEC_GPU = $(BIN_DIR)/geneferg_arm

.PHONY: all clean_obj rebuild

all: $(EXEC_CPU) $(EXEC_GPU)

clean_obj:
	$(RM) $(OBJS_CPU) $(OBJS_GPU)

rebuild: clean_obj all

main.o: $(SRC_DIR)/main.cpp $(DEPS_MAIN)
	$(CC) $(CFLAGS) $(FLAGS_CPU) -c $< -o $@

maing.o: $(SRC_DIR)/main.cpp $(DEPS_MAIN)
	$(CC) $(CFLAGS) $(FLAGS_GPU) $(OCL_INC) -c $< -o $@

transform_neon.o: $(SRC_DIR)/transform_neon.cpp $(DEPS_TRANSFORM_CPUf64)
	$(CC) $(CFLAGS) $(OFLAGS) $(FLAGS_CPU) -c $< -o $@
#	$(CC) $(CFLAGS) $(OFLAGS) $(FLAGS_CPU) -c -S $< -o neon.asm

sve_size.o: $(SRC_DIR)/sve_size.cpp $(DEPS_TRANSFORM_CPUf64)
	$(CC) $(CFLAGS) $(FLAGS_CPU) -march=armv8-a+sve -c $< -o $@

transform_sve128.o: $(SRC_DIR)/transform_sve128.cpp $(DEPS_TRANSFORM_CPUf64)
	$(CC) $(CFLAGS) $(OFLAGS) $(FLAGS_CPU) -march=armv8-a+sve -msve-vector-bits=128 -mtune=neoverse-512tvb -c $< -o $@
#	$(CC) $(CFLAGS) $(OFLAGS) $(FLAGS_CPU) -march=armv8-a+sve -msve-vector-bits=128 -mtune=neoverse-512tvb -c -S $< -o sve128.asm

transform_sve256.o: $(SRC_DIR)/transform_sve256.cpp $(DEPS_TRANSFORM_CPUf64)
	$(CC) $(CFLAGS) $(OFLAGS) $(FLAGS_CPU) -march=armv8-a+sve -msve-vector-bits=256 -mtune=neoverse-v1 -c $< -o $@
#	$(CC) $(CFLAGS) $(OFLAGS) $(FLAGS_CPU) -march=armv8-a+sve -msve-vector-bits=256 -mtune=neoverse-v1 -c -S $< -o sve256.asm

transform_sve512.o: $(SRC_DIR)/transform_sve512.cpp $(DEPS_TRANSFORM_CPUf64)
	$(CC) $(CFLAGS) $(OFLAGS) $(FLAGS_CPU) -march=armv8-a+sve -msve-vector-bits=512 -mtune=a64fx -c $< -o $@
#	$(CC) $(CFLAGS) $(OFLAGS) $(FLAGS_CPU) -march=armv8-a+sve -msve-vector-bits=512 -mtune=a64fx -S $< -o sve512.asm

transform_ocl.o: $(SRC_DIR)/transform_ocl.cpp $(DEPS_TRANSFORM_GPU)
	$(CC) $(CFLAGS) $(FLAGS_GPU) $(OCL_INC) -c $< -o $@

$(EXEC_CPU): $(OBJS_CPU)
	$(CC) $(FLAGS_CPU) -static $^ -lgmp $(BOINC_LIB) -o $@

$(EXEC_GPU): $(OBJS_GPU)
	$(CC) $(FLAGS_GPU) -static-libgcc -static-libstdc++ $^ /usr/lib/aarch64-linux-gnu/libgmp.a $(BOINC_LIB) $(BOINC_LIB_OCL) $(OCL_LIB) -o $@
